# Telegram Bot API Configuration (optional - for bot features)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Telegram User API Configuration (required for chat sync)
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Encryption key for session storage (generate with: openssl rand -hex 16)
TELEGRAM_SESSION_KEY=your_32_character_encryption_key

# Attio API Configuration
ATTIO_API_KEY=your_attio_api_key_here

# File Storage Configuration (optional)
S3_BUCKET=your_s3_bucket_for_file_storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1