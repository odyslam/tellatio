# Telegram API credentials — get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Session string — run: pnpm login:telegram
TELEGRAM_SESSION=

# Attio API key — get from Attio workspace settings
ATTIO_API_KEY=

# Sync source:
# - associations: sync only approved Attio Telegram Association records
# - folder: legacy mode, sync chats from TELEGRAM_FOLDER_NAME
TELLATIO_SYNC_SOURCE=associations

# Optional: Attio custom object slug used for chat associations
TELLATIO_ASSOCIATION_OBJECT=telegram_associations

# Optional: Attio custom object slug used for Telegram user -> Person mappings
TELLATIO_IDENTITY_OBJECT=telegram_identities

# Optional: create Person records for unmatched DMs when no safe identity match exists.
# Default false keeps ambiguous Telegram users in identity review instead of creating duplicates.
TELLATIO_AUTO_CREATE_PEOPLE=false

# Optional: also allow legacy folder-mode group participants to create Person records.
# Default false prevents tracked groups from spawning junk People for random participants.
TELLATIO_AUTO_CREATE_GROUP_PEOPLE=false

# Optional: fall back to TELEGRAM_FOLDER_NAME when no approved associations exist
TELLATIO_FOLDER_FALLBACK_ENABLED=false

# Optional: per-chat Telegram fetch timeout so one stale/inaccessible chat cannot block a cycle
TELLATIO_CHAT_FETCH_TIMEOUT_SECONDS=30

# Optional: Telegram folder name for legacy fallback mode
TELEGRAM_FOLDER_NAME=Attio

# Optional: Sync interval in minutes (default: 15). Use SYNC_INTERVAL_SECONDS
# instead when you need exact worker cadence, for example on Railway.
SYNC_INTERVAL_MINUTES=15
# SYNC_INTERVAL_SECONDS=900

# Optional: Number of recent Telegram dialogs to scan for approved association IDs
TELLATIO_DISCOVERY_DIALOG_LIMIT=1000

# Optional: Company/product names to ignore when profile bios mention your own org
TELLATIO_OWN_COMPANY_NAMES=Phylax,Phylax Systems,Credible Layer

# Optional: Directory for sync state file (default: /data)
DATA_DIR=/data
