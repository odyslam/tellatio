#!/usr/bin/env sh
set -eu

PRG="$0"
while [ -h "$PRG" ]; do
  LINK=$(expr "$(ls -ld "$PRG")" : '.*-> \(.*\)$')
  case "$LINK" in
    /*) PRG="$LINK" ;;
    *) PRG=$(dirname "$PRG")/"$LINK" ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$PRG")" && pwd)
ROOT_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

exec bun "$ROOT_DIR/src/cli.ts" "$@"
